{
	"name": "konradmichalik/solr-dashboard-widgets",
	"description": "Solr Dashboard Widgets for TYPO3 Backend",
	"license": [
		"GPL-2.0-or-later"
	],
	"type": "typo3-cms-extension",
	"authors": [
		{
			"name": "Konrad Michalik",
			"email": "hej@konradmichalik.dev",
			"role": "Maintainer"
		}
	],
	"require": {
		"php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
		"apache-solr-for-typo3/solr": "^12.0 || ^13.0 || ^14.0@alpha",
		"typo3/cms-core": "^12.0 || ^13.0 || ^14.0",
		"typo3/cms-dashboard": "^12.0 || ^13.0 || ^14.0"
	},
	"require-dev": {
		"eliashaeussler/version-bumper": "^2.4 || ^3.0",
		"phpunit/phpcov": "^9.0 || ^10.0 || ^11.0",
		"phpunit/phpunit": "^10.2 || ^11.0 || ^12.0",
		"typo3/cms-base-distribution": "^12.4 || ^13.4 || ^14.0"
	},
	"autoload": {
		"psr-4": {
			"KonradMichalik\\SolrDashboardWidgets\\": "Classes/"
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"config": {
		"allow-plugins": {
			"eliashaeussler/version-bumper": true,
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		},
		"sort-packages": true
	},
	"extra": {
		"konradmichalik/php-cs-fixer-preset": {
			"copyright": 2026
		},
		"typo3/cms": {
			"cms-package-dir": "{$vendor-dir}/typo3/cms",
			"extension-key": "solr_dashboard_widgets",
			"web-dir": "public"
		}
	},
	"scripts": {
		"post-install-cmd": [
			"@cgl install"
		],
		"cgl": "@composer -d Tests/CGL --",
		"test": "@test:coverage --no-coverage",
		"test:coverage": "XDEBUG_MODE=coverage phpunit -c phpunit.xml"
	}
}
