<?xml version="1.0" encoding="UTF-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
	<file source-language="en" target-language="de" datatype="plaintext" original="messages" date="2026-04-14T00:00:00Z" product-name="solr_dashboard_widgets">
		<header/>
		<body>
			<trans-unit id="group.solr.label" resname="group.solr.label">
				<source>Apache Solr</source>
				<target>Apache Solr</target>
			</trans-unit>

			<trans-unit id="widget.connectionStatus.title" resname="widget.connectionStatus.title">
				<source>Solr Connection Status</source>
				<target>Solr-Verbindungsstatus</target>
			</trans-unit>
			<trans-unit id="widget.connectionStatus.description" resname="widget.connectionStatus.description">
				<source>Shows the connection status for each configured Solr core.</source>
				<target>Zeigt den Verbindungsstatus für jeden konfigurierten Solr-Core.</target>
			</trans-unit>

			<trans-unit id="widget.indexQueueStatus.title" resname="widget.indexQueueStatus.title">
				<source>Index Queue Status</source>
				<target>Index-Warteschlangen-Status</target>
			</trans-unit>
			<trans-unit id="widget.indexQueueStatus.description" resname="widget.indexQueueStatus.description">
				<source>Visualizes the index queue status as a donut chart (indexed, pending, failed).</source>
				<target>Visualisiert den Status der Index-Warteschlange als Donut-Diagramm (indiziert, ausstehend, fehlgeschlagen).</target>
			</trans-unit>

			<trans-unit id="widget.indexQueueStatus.indexed" resname="widget.indexQueueStatus.indexed">
				<source>Indexed</source>
				<target>Indiziert</target>
			</trans-unit>
			<trans-unit id="widget.indexQueueStatus.pending" resname="widget.indexQueueStatus.pending">
				<source>Pending</source>
				<target>Ausstehend</target>
			</trans-unit>
			<trans-unit id="widget.indexQueueStatus.failed" resname="widget.indexQueueStatus.failed">
				<source>Failed</source>
				<target>Fehlgeschlagen</target>
			</trans-unit>

			<trans-unit id="widget.connectionStatus.noConnections" resname="widget.connectionStatus.noConnections">
				<source>No Solr connections configured.</source>
				<target>Keine Solr-Verbindungen konfiguriert.</target>
			</trans-unit>

			<trans-unit id="widget.indexQueueErrors.title" resname="widget.indexQueueErrors.title">
				<source>Index Queue Errors</source>
				<target>Index-Warteschlangen-Fehler</target>
			</trans-unit>
			<trans-unit id="widget.indexQueueErrors.description" resname="widget.indexQueueErrors.description">
				<source>Lists the most recent failed indexing attempts.</source>
				<target>Listet die letzten fehlgeschlagenen Indexierungsversuche auf.</target>
			</trans-unit>
			<trans-unit id="widget.indexQueueErrors.resetButton" resname="widget.indexQueueErrors.resetButton">
				<source>Reset all errors</source>
				<target>Alle Fehler zurücksetzen</target>
			</trans-unit>
			<trans-unit id="widget.indexQueueErrors.resetConfirm" resname="widget.indexQueueErrors.resetConfirm">
				<source>Are you sure you want to reset all index queue errors?</source>
				<target>Möchten Sie wirklich alle Fehler der Index-Warteschlange zurücksetzen?</target>
			</trans-unit>
			<trans-unit id="widget.indexQueueErrors.noErrors" resname="widget.indexQueueErrors.noErrors">
				<source>No indexing errors found.</source>
				<target>Keine Indexierungsfehler gefunden.</target>
			</trans-unit>
			<trans-unit id="widget.indexQueueErrors.recordType" resname="widget.indexQueueErrors.recordType">
				<source>Record Type</source>
				<target>Datensatztyp</target>
			</trans-unit>
			<trans-unit id="widget.indexQueueErrors.uid" resname="widget.indexQueueErrors.uid">
				<source>UID</source>
				<target>UID</target>
			</trans-unit>
			<trans-unit id="widget.indexQueueErrors.error" resname="widget.indexQueueErrors.error">
				<source>Error</source>
				<target>Fehler</target>
			</trans-unit>
			<trans-unit id="widget.indexQueueErrors.timestamp" resname="widget.indexQueueErrors.timestamp">
				<source>Timestamp</source>
				<target>Zeitstempel</target>
			</trans-unit>

			<trans-unit id="widget.documentsInIndex.title" resname="widget.documentsInIndex.title">
				<source>Documents in Index</source>
				<target>Dokumente im Index</target>
			</trans-unit>
			<trans-unit id="widget.documentsInIndex.description" resname="widget.documentsInIndex.description">
				<source>Shows the number of indexed documents per Solr core as a bar chart.</source>
				<target>Zeigt die Anzahl der indizierten Dokumente pro Solr-Core als Balkendiagramm.</target>
			</trans-unit>
			<trans-unit id="widget.documentsInIndex.unreachable" resname="widget.documentsInIndex.unreachable">
				<source>Unreachable</source>
				<target>Nicht erreichbar</target>
			</trans-unit>

			<trans-unit id="widget.lastIndexingRun.title" resname="widget.lastIndexingRun.title">
				<source>Last Indexing Run</source>
				<target>Letzter Indexierungslauf</target>
			</trans-unit>
			<trans-unit id="widget.lastIndexingRun.description" resname="widget.lastIndexingRun.description">
				<source>Shows the timestamp of the last Solr indexer scheduler run.</source>
				<target>Zeigt den Zeitstempel des letzten Solr-Indexer-Scheduler-Laufs.</target>
			</trans-unit>
			<trans-unit id="widget.lastIndexingRun.ago" resname="widget.lastIndexingRun.ago">
				<source>%s ago</source>
				<target>vor %s</target>
			</trans-unit>
			<trans-unit id="widget.lastIndexingRun.never" resname="widget.lastIndexingRun.never">
				<source>No indexing run found.</source>
				<target>Kein Indexierungslauf gefunden.</target>
			</trans-unit>

			<trans-unit id="widget.searchStatistics.title" resname="widget.searchStatistics.title">
				<source>Search Statistics</source>
				<target>Suchstatistiken</target>
			</trans-unit>
			<trans-unit id="widget.searchStatistics.description" resname="widget.searchStatistics.description">
				<source>Displays top search terms, no-hit queries, and search volume over time.</source>
				<target>Zeigt die häufigsten Suchbegriffe, Suchen ohne Treffer und das Suchvolumen im Zeitverlauf.</target>
			</trans-unit>
			<trans-unit id="widget.searchStatistics.topSearchTerms" resname="widget.searchStatistics.topSearchTerms">
				<source>Top Search Terms</source>
				<target>Häufigste Suchbegriffe</target>
			</trans-unit>
			<trans-unit id="widget.searchStatistics.noHitQueries" resname="widget.searchStatistics.noHitQueries">
				<source>Queries Without Results</source>
				<target>Suchen ohne Treffer</target>
			</trans-unit>
			<trans-unit id="widget.searchStatistics.searchVolume" resname="widget.searchStatistics.searchVolume">
				<source>Search Volume</source>
				<target>Suchvolumen</target>
			</trans-unit>
			<trans-unit id="widget.searchStatistics.noDataHint" resname="widget.searchStatistics.noDataHint">
				<source>Statistics are disabled or no data is available yet.</source>
				<target>Statistiken sind deaktiviert oder noch keine Daten vorhanden.</target>
			</trans-unit>
			<trans-unit id="widget.searchStatistics.activationHint" resname="widget.searchStatistics.activationHint">
				<source>Enable plugin.tx_solr.statistics = 1 in your TypoScript configuration.</source>
				<target>Aktiviere plugin.tx_solr.statistics = 1 in deinem TypoScript.</target>
			</trans-unit>

			<trans-unit id="preset.solrOverview.title" resname="preset.solrOverview.title">
				<source>Solr Overview</source>
				<target>Solr-Übersicht</target>
			</trans-unit>
			<trans-unit id="preset.solrOverview.description" resname="preset.solrOverview.description">
				<source>A predefined dashboard with all Solr widgets.</source>
				<target>Ein vordefiniertes Dashboard mit allen Solr-Widgets.</target>
			</trans-unit>
		</body>
	</file>
</xliff>
